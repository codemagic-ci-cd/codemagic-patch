{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowPublicReadOnPublicArtifacts",
      "Effect": "Allow",
      "Principal": "*",
      "Action": ["s3:GetObject"],
      "Resource": ["arn:aws:s3:::codemagic-patch/*"]
    },
    {
      "Sid": "DenyPublicReadOnInternalPrefix",
      "Effect": "Deny",
      "Principal": "*",
      "Action": ["s3:GetObject"],
      "Resource": ["arn:aws:s3:::codemagic-patch/_internal/*"]
    }
  ]
}
