# Local dev: dashboard + API + mock GitHub on a single origin (browser :5173).
:5173 {
	encode gzip

	handle /v1/* {
		reverse_proxy server:3000
	}

	handle /health* {
		reverse_proxy server:3000
	}

	handle_path /mock-github/* {
		reverse_proxy mock-github:4480
	}

	handle {
		root * /srv/dashboard
		try_files {path} /index.html
		file_server
	}
}
