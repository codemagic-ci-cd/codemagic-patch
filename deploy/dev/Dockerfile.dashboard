# syntax=docker/dockerfile:1.7

# Local dev dashboard image: SPA (mock GitHub OAuth via /mock-github) + Caddy.
FROM node:22.20.0-alpine AS builder

ARG VITE_OAUTH_AUTHORIZE_BASE_URL=http://127.0.0.1:5173/mock-github

WORKDIR /workspace

ENV CI=1 \
    YARN_ENABLE_TELEMETRY=0 \
    VITE_OAUTH_AUTHORIZE_BASE_URL=${VITE_OAUTH_AUTHORIZE_BASE_URL}

RUN corepack enable

COPY package.json yarn.lock .yarnrc.yml ./
COPY cli/package.json ./cli/
COPY client/package.json ./client/
COPY infra/pulumi/package.json ./infra/pulumi/
COPY server/package.json ./server/
COPY shared/package.json ./shared/
COPY web-dashboard/package.json ./web-dashboard/

RUN yarn workspaces focus codemagic-patch-monorepo web-dashboard

COPY tsconfig.base.json ./
COPY shared ./shared
COPY web-dashboard ./web-dashboard

RUN yarn workspace web-dashboard build

FROM caddy:2-alpine AS runtime

COPY --from=builder /workspace/web-dashboard/dist /srv/dashboard
