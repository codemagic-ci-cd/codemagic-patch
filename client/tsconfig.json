{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@codemagic/react-native-patch": ["./src/index.ts"],
      "@codemagic/react-native-patch/testing": ["./testing.ts"]
    },
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.tsbuildinfo"
  },
  "include": [
    "src/**/*.ts",
    "testing.ts",
    "test/**/*.ts",
    "e2e/**/*.ts",
    "plugin/**/*.ts"
  ]
}
