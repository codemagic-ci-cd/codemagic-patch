{
  "name": "web-dashboard",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "yarn workspace @codemagic/patch-shared build && vite build",
    "clean": "rimraf dist node_modules/.cache",
    "dev": "vite",
    "lint": "eslint --no-error-on-unmatched-pattern \"src/**/*.{ts,tsx}\" \"test/**/*.{ts,tsx}\"",
    "test": "yarn workspace @codemagic/patch-shared build && vitest run",
    "typecheck": "yarn workspace @codemagic/patch-shared build && tsc --noEmit"
  },
  "dependencies": {
    "@codemagic/patch-shared": "workspace:*",
    "@tanstack/react-query": "^5.101.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router": "^7.17.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.4.0",
    "jsdom": "^29.1.1",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^3.2.4"
  }
}
