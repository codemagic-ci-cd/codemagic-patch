{
  "name": "codemagic-patch-monorepo",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "packageManager": "yarn@4.12.0",
  "workspaces": [
    "cli",
    "client",
    "docs-site",
    "server",
    "shared",
    "web-dashboard"
  ],
  "engines": {
    "node": ">=22.20.0"
  },
  "scripts": {
    "build": "yarn workspaces foreach -A -t run build",
    "cli:install-global": "yarn workspace @codemagic/patch-cli build && rm -rf .tmp-pack && mkdir -p .tmp-pack && cd cli && npm pack --silent --pack-destination ../.tmp-pack && cd .. && npm install -g .tmp-pack/*.tgz && rm -rf .tmp-pack",
    "clean": "yarn workspaces foreach -A run clean && rimraf coverage",
    "fixtures:package-hash": "yarn exec tsx shared/test-vectors/package-hash/generate.ts",
    "lint": "yarn workspaces foreach -A run lint",
    "test": "yarn workspaces foreach -A run test",
    "typecheck": "yarn workspaces foreach -A -t run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@react-native-community/cli": "^20.1.3",
    "@types/node": "^22.18.10",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "eslint": "^9.36.0",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
